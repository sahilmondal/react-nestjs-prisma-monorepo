{
  "name": "react-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "generate": "turbo generate",
    "db:generate": "bun --filter @workspace/db db:generate",
    "db:push": "bun --filter @workspace/db db:push",
    "db:migrate": "bun --filter @workspace/db db:migrate",
    "db:seed": "bun --filter @workspace/db db:seed",
    "db:studio": "bun --filter @workspace/db db:studio",
    "db:reset": "bun --filter @workspace/db db:reset",
    "postinstall": "bun --filter @workspace/db db:generate"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "ajv": "^8.20.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.2.6",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "ui/apps/*",
    "ui/shared/*",
    "api/*",
    "packages/*"
  ]
}
