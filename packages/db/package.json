{
  "name": "@workspace/db",
  "private": true,
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:reset": "prisma migrate reset --config prisma.config.ts --force",
    "build": "bun run db:generate && tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.2.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "@workspace/typescript-config": "workspace:*",
    "prisma": "^7.8.0",
    "typescript": "^6.0.2"
  }
}
