{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "es2022",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
