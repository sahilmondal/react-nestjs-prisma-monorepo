{
  "name": "@workspace/ui-utils",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Utility functions and helpers for UI and business logic",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
